{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "API_BASE_URL",
    "NEXT_PUBLIC_API_BASE_URL",
    "API_PORT",
    "WEB_PORT",
    "WEB_ORIGIN",
    "APP_TIMEZONE",
    "APIFY_TOKEN",
    "APIFY_ACTOR_ID",
    "ANTHROPIC_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    }
  }
}
