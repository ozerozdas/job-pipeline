{
  "name": "job-pipeline",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "dotenv -e .env -- turbo dev",
    "build": "dotenv -e .env -- turbo build",
    "docker:up": "docker compose --env-file .env up -d postgres",
    "docker:down": "docker compose down",
    "db:generate": "dotenv -e .env -- pnpm --filter @job-pipeline/db db:generate",
    "db:push": "dotenv -e .env -- pnpm --filter @job-pipeline/db db:push",
    "db:studio": "dotenv -e .env -- pnpm --filter @job-pipeline/db db:studio",
    "postinstall": "pnpm db:generate"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "turbo": "^2.5.0",
    "typescript": "^5.7.2"
  }
}
