{
  "name": "job-pipeline",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "dotenv -e .env -- turbo dev --filter=!@job-pipeline/cli",
    "build": "dotenv -e .env -- turbo build",
    "docker:build": "docker build -t ozerozdas/job-pipeline:latest .",
    "docker:publish": "docker push ozerozdas/job-pipeline:latest",
    "docker:app": "docker compose --profile app up -d --build",
    "docker:up": "docker compose --env-file .env up -d postgres",
    "docker:down": "docker compose down",
    "db:generate": "dotenv -e .env -- pnpm --filter @job-pipeline/db db:generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @job-pipeline/db db:migrate",
    "db:push": "dotenv -e .env -- pnpm --filter @job-pipeline/db db:push",
    "db:studio": "dotenv -e .env -- pnpm --filter @job-pipeline/db db:studio",
    "cli": "dotenv -e .env -- node --import tsx/esm apps/cli/src/index.ts",
    "postinstall": "pnpm db:generate"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "turbo": "^2.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
